# SSH Configuration
# Managed by chezmoi — edit the source, not this file

# Global defaults
Host *
    AddKeysToAgent yes
    IdentityAgent ~/.ssh/agent.sock
    ForwardAgent no
    Compression yes
    # No TCP keepalive — use SSH-level instead
    TCPKeepAlive no
    ServerAliveInterval 60
    ServerAliveCountMax 3
    # Connection reuse
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 10m

# ── Local servers ──

# TrueNAS server (direct LAN access)
Host truenas
    HostName {{ .truenas_ip | default "192.168.1.3" }}
    User truenas_admin
    IdentityFile ~/.ssh/id_ed25519

# ── Cloud / Git ──

# Forgejo Git SSH via Cloudflare Tunnel
Host {{ .forgejo_ssh_host | default "ssh.wyattau.com" }}
    ProxyCommand {{ .cloudflared_path | default "~/.local/bin/cloudflared" }} access ssh --hostname %h
    User git
    Port 22
    IdentityFile ~/.ssh/id_ed25519

# ── GitHub ──
Host github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    # GitHub doesn't need keepalive for quick pushes

# ── WSL / localhost ──
Host localhost 127.0.0.1
    User {{ .name | default "wyatt" | lower | replace " " "" }}
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
