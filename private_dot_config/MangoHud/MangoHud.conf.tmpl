# MangoHud — Gaming performance overlay
# Configuration: https://github.com/flightlessmango/MangoHud

# === CORE METRICS ===
fps
frametime=1
frame_count=1
frame_timing=1

# === CPU ===
cpu_stats
cpu_temp
cpu_mhz

# === GPU ===
gpu_stats
gpu_temp
gpu_power
gpu_fan
gpu_voltage
gpu_core_clock
gpu_mem_clock

# === MEMORY ===
ram
vram
swap

# === DISPLAY ===
position=top-left
width=300
background_alpha=0.5
font_size=small
toggle_hud=Shift_R+F12
toggle_logging=Shift_L+F2
output_folder=/home/{{ .chezmoi.username }}
