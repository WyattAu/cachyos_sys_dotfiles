# GDB — GNU Debugger configuration
# Pretty-printers and display defaults

# Always show the TUI interface in terminals
set pagination off
set print pretty on
set print array on
set print array-indexes on
set print elements 0

# History
set history save on
set history size 10000
set history filename ~/.gdb_history

# Auto-load pretty-printers
set auto-load safe-path /

# Show arguments in backtrace
set backtrace show-arguments on
set backtrace limit 32
