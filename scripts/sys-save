#!/bin/bash
set -e
cd ~/.local/share/chezmoi

# 1. Re-add only the specific managed configs (NEVER blanket-re-add directories)
#    Add new files explicitly: chezmoi add ~/.config/<app>/config-file
echo ">> Syncing managed dotfiles..."
chezmoi re-add \
  ~/.config/fish/config.fish \
  ~/.config/fish/functions/__ghq_fzf_repo.fish \
  ~/.config/kitty/kitty.conf \
  ~/.config/nvim/init.lua \
  ~/.config/starship.toml \
  ~/.config/kdeglobals \
  ~/.config/kwinrc \
  ~/.config/plasmashellrc \
  ~/.config/kglobalshortcutsrc \
  > /dev/null 2>&1 || true

# 2. Stage and commit if there are changes
if [[ -n $(git status -s) ]]; then
    MSG="${1:-Auto-save $(date +'%Y-%m-%d %H:%M')}"
    git add .
    git commit -m "$MSG"
    echo ">> Pushing to GitHub..."
    git push origin master
    echo ">> Done."
else
    echo ">> No changes to save."
fi
