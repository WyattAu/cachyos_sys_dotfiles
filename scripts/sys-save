#!/bin/bash
set -e
cd ~/.local/share/chezmoi

# Re-add all managed files that differ between source and target.
# This captures any on-machine edits to dotfiles, configs, and Neovim plugins.
#
# kdeglobals is excluded: KDE replaces ColorScheme names with hashes and
# drops widgetStyle/[Icons] on write. Re-adding would overwrite our fix.
echo ">> Syncing managed dotfiles..."

# Build exclude list (files that drift due to application behavior)
EXCLUDE_PATTERNS="kdeglobals"

# Get all managed files, filter out excludes, re-add
chezmoi managed --include=files 2>/dev/null | while read -r file; do
  skip=false
  for pattern in $EXCLUDE_PATTERNS; do
    if echo "$file" | grep -q "$pattern"; then
      skip=true
      break
    fi
  done
  if [ "$skip" = false ]; then
    chezmoi re-add "$file" > /dev/null 2>&1 || true
  fi
done

# Stage and commit if there are changes
if [[ -n $(git status -s) ]]; then
    MSG="${1:-Auto-save $(date +'%Y-%m-%d %H:%M')}"
    git add .
    git commit -m "$MSG"
    echo ">> Pushing to GitHub..."
    git push origin master
    echo ">> Done."
else
    echo ">> No changes to save."
fi
